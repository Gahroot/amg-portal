{
  "expo": {
    "name": "AMG Portal",
    "slug": "amg-portal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "amgportal",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amg.portal",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow AMG Portal to use speech recognition for dictating messages and notes.",
        "NSMicrophoneUsageDescription": "Allow AMG Portal to access your microphone for voice-to-text dictation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.amg.portal",
      "permissions": [
        "NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "certPins": {
        "api.amg-portal.com": {
          "primary": "REPLACE_WITH_PROD_LEAF_SPKI_SHA256",
          "backup": "REPLACE_WITH_BACKUP_SPKI_SHA256",
          "expiration": "2027-01-01"
        }
      },
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.amg.portal.widgets",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.amg.portal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "2fb4a728-ee67-42af-aba8-aeebbf905f66"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "./plugins/withCertificatePinning",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0f172a"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow AMG Portal to access your microphone for voice-to-text dictation.",
          "speechRecognitionPermission": "Allow AMG Portal to use speech recognition for dictating messages and notes."
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.amg.portal.widgets",
          "groupIdentifier": "group.com.amg.portal",
          "widgets": [
            {
              "name": "TasksWidget",
              "displayName": "AMG Tasks",
              "description": "View pending approvals and tasks at a glance",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge",
                "accessoryCircular",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ]
    ],
    "owner": "gahroot"
  }
}
